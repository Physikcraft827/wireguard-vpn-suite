{
  "name": "wireguard-server-studio",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder --win nsis",
    "electron:dev": "concurrently \"vite\" \"electron .\""
  },
  "build": {
    "appId": "com.wireguard.serverstudio",
    "productName": "WireGuard Server Studio",
    "directories": {
      "output": "dist-executable"
    },
    "win": {
      "target": "nsis",
      "requestedExecutionLevel": "requireAdministrator"
    }
  },
  "dependencies": {
    "lucide-react": "^0.344.0",
    "qrcode": "^1.5.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.2.61",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^29.1.0",
    "typescript": "^5.3.3",
    "vite": "^5.1.4"
  }
}
